# ============================================================
# FOREX SMC ANALYZER — Environment Configuration Template
# ============================================================
# Copy file ini menjadi ".env" dan isi dengan credentials kamu sendiri.
# JANGAN share file ".env" yang sudah diisi — bersifat PRIVATE.
# ============================================================

# --- TELEGRAM ---
# Buat bot baru via @BotFather di Telegram, lalu isi token-nya.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# Chat ID akun Telegram kamu. Bisa dicek via @userinfobot.
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# --- MT5 EXECUTION ---
# Set True untuk mengaktifkan auto-trading ke MetaTrader 5.
MT5_EXECUTE_TRADES=False
MT5_REQUIRE_ROLLOUT_READY=False

# Lot size per order. Sesuaikan dengan ukuran akun kamu.
MT5_LOT_SIZE_OPTION_A=0.01
MT5_LOT_SIZE_OPTION_B=0.01

# Magic number UNIK untuk bot kamu. Ganti angka ini supaya tidak
# bentrok dengan bot lain atau session manual. Contoh: 202610
MT5_MAGIC_NUMBER=202610

# --- DYNAMIC LOT SIZING ---
MT5_DYNAMIC_LOT_ENABLED=True
MT5_DYNAMIC_LOT_BASE_BALANCE_IDR=2000000
MT5_DYNAMIC_LOT_BALANCE_STEP_IDR=2000000
MT5_DYNAMIC_LOT_BASE_BALANCE_USD=100
MT5_DYNAMIC_LOT_BALANCE_STEP_USD=100
MT5_DYNAMIC_LOT_BASE_LOT=0.01
MT5_DYNAMIC_LOT_STEP_LOT=0.01
MT5_DYNAMIC_LOT_MAX=0.05

# --- TAKE PROFIT MODE ---
# "fibo0" = TP di Fib 0 (awal swing). Alternatif: "fixed"
MT5_SERVER_TP_MODE=fibo0

# --- RUNNER (Trailing Mechanism) ---
MT5_RUNNER_ENABLED=True
MT5_RUNNER_ARM_DISTANCE_PIPS=10
MT5_RUNNER_PROTECT_PIPS=2
MT5_RUNNER_EXHAUSTION_RETRACE_PIPS=25
MT5_RUNNER_MAX_SPREAD_PIPS=5
MT5_RUNNER_REQUIRE_CONFLUENCE=True

# --- EARLY MITIGATION (Keluar lebih awal jika sinyal reversal) ---
MT5_EARLY_MITIGATION_ENABLED=False
MT5_EARLY_MITIGATION_MIN_ADVERSE_PIPS=35
MT5_EARLY_MITIGATION_RISK_FRACTION=0.40
MT5_EARLY_MITIGATION_VOLUME_MULTIPLIER=2.0
MT5_EARLY_MITIGATION_MAX_SPREAD_PIPS=12

# --- PROFIT LOCK / TRAILING STOP ---
# Untuk XAUUSD: custom ladder aktif otomatis (tidak perlu ubah di sini).
# < 80 pips: tidak ada perubahan SL
# 80–149 pips: SL geser ke BEP
# >= 150 pips: trailing ladder (floor(pips/50)*50 - 100)
MT5_PROFIT_LOCK_ENABLED=True
MT5_CUSTOM_STAGED_PROFIT_LOCK=False
MT5_PROFIT_LOCK_STEP_PIPS=50
MT5_PROFIT_LOCK_GAP_PIPS=50

# --- RISK MANAGEMENT ---
MT5_MAX_CONCURRENT_TRADES=6
MT5_MAX_PENDING_ORDERS=8
MT5_ALLOW_MIXED_STRATEGIES_PER_TF=True
MT5_PENDING_PROXIMITY_PIPS=15.0
MT5_SAME_TF_PROXIMITY_PIPS=30.0
MT5_CLUSTER_PROXIMITY_USD=1.5
MT5_ALLOWED_TIMEFRAMES=M30,H1,H4,D1
MT5_MAX_PENDING_DISTANCE_PIPS=200.0
MT5_RECOVERY_MAX_RETRIES=2

# --- DAILY GOVERNOR (Batas harian — opsional) ---
MT5_DAILY_GOVERNOR_ENABLED=False
MT5_DAILY_MIN_TARGET_PIPS=100
MT5_DAILY_RUNNER_TARGET_PIPS=300
MT5_DAILY_MAX_LOSS_PIPS=200
MT5_DAILY_MAX_CONSECUTIVE_LOSSES=3

# --- STRATEGY FILTER ---
MT5_LIVE_STRATEGY_ALLOWLIST=FVG_OR_BPR,OB_OR_SWAPZONE_IC_SND
MT5_LIVE_STRATEGY_BLOCKLIST=Pivot,SND,Swapzone,IC

# --- ML / AI CONFIDENCE ---
ML_ACCEPT_THRESHOLD=0.50
ML_LIVE_MIN_THRESHOLD=0.50
ML_ENTRY_BASE_THRESHOLD=0.50
ML_ENTRY_BUY_CONFIDENCE_BONUS=0.00
ML_RETRAIN_THRESHOLD=10
ML_RETRAIN_ON_WEEKEND=true
ML_TRAINING_MAX_SETUPS=5000
ML_HIGH_CONFIDENCE_TIER=0.65
ML_ULTRA_CONFIDENCE_TIER=0.80

# --- ENTRY GATE & SPREAD ---
MT5_ENFORCE_ENTRY_GATE=False
MT5_ENFORCE_SPREAD_FILTER=True
MT5_MAX_SPREAD_RATIO=0.20

# --- PRICE WATCH ZONES (sistem deteksi entry real-time) ---
WATCH_ZONE_TTL_MINUTES=120
WATCH_ZONE_MAX_PER_SYMBOL=40
WATCH_ZONE_APPROACH_BUFFER=0.30
